{
    "hyprland/workspaces": {
        "on-click": "activate",
        "active-only": false,
        "all-outputs": true,
        "format": "{icon}   ({id})",
        "format-icons": {
           "1": "п‰Ѕ",
           "2": "оЄ…",
           "3": "оњј",
           "4": "пЂЃ",
           "5": "у±њЏ",
           "6": "о‰µ",
           "empty": ""
        },
        "persistent-workspaces": {
            "*": 6
        }       
    },

    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 18,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close",
        "ignore-list": [
           "Alacritty"
        ],
        "app_ids-mapping": {
            "firefoxdeveloperedition": "firefox-developer-edition"
        },
        "rewrite": {
            "Firefox Web Browser": "Firefox",
            "Foot Server": "Terminal"
        }
    },

    "hyprland/window": {
        "separate-outputs": true
    },

    "custom/empty": {
        "format": ""
    },

    "custom/updates": {
        "format": "п‚«   {}",
        "tooltip-format": "{}",
        "escape": true,
        "return-type": "json",
        "exec": "~/scripts/arch/available_updates.sh",
        "restart-interval": 60,
        "on-click": "wezterm -e ~/scripts/arch/install_updates.sh",
        "on-click-right": "wezterm -e pacseek",
        "tooltip": false
    },

    "custom/filemanager": {
        "format": "пЃј",
        "on-click": "thunar",
        "tooltip": false
    },

    "custom/browser": {
        "format": "п‰Ё",
        "on-click": "vivaldi",
        "tooltip": false
    },    

    "custom/llm": {
        "format": " ",
        "on-click": "chromium --app=https://claude.ai",
        "tooltip": false
    },

    "custom/appmenu": {
        "format": "Apps",
        "on-click": "sleep 0.2;rofi -show drun -replace",
        "on-click-right": "~/scripts/hypr/keybindings.sh",
        "tooltip": false
    },

    "custom/exit": {
        "format": "пЂ‘",
        "on-click": "wlogout",
        "tooltip": false
    },

    "tray": {
        "icon-size": 21,
        "spacing": 10
    },

    "clock": {
        "format": "{:%H:%M %a}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },

    "cpu": {
        "format": "/ C {usage}% ",
        "on-click": "alacritty -e htop"
    },

    "memory": {
        "format": "/ M {}% ",
        "on-click": "alacritty -e htop"
    },

    "disk": {
        "interval": 30,
        "format": "D {percentage_used}% ",
        "path": "/",
        "on-click": "alacritty -e htop"
    }, 

    "hyprland/language": {
        "format": "/ K {short}"
    },

    "group/hardware": {
        "orientation": "horizontal",
        "modules": [
            "disk",
            "cpu",
            "memory",
            "hyprland/language"
        ]
    },
    
    "group/links": {
        "orientation": "horizontal",
        "modules": [
            "custom/llm",
            "custom/browser",
            "custom/filemanager"
        ]
    },

    "network": {
        "format": "{ifname}",
        "format-wifi": "п‡«   {signalStrength}%",
        "format-ethernet": "пћ–  {ifname}",
        "format-disconnected": "Disconnected",
        "tooltip-format": "пћ– {ifname} via {gwaddri}",
        "tooltip-format-wifi": "п‡«  {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\nUp: {bandwidthUpBits} Down: {bandwidthDownBits}",
        "tooltip-format-ethernet": "пћ– {ifname}\nIP: {ipaddr}\n up: {bandwidthUpBits} down: {bandwidthDownBits}",
        "tooltip-format-disconnected": "Disconnected",
        "max-length": 50,
        "on-click": "nm-connection-editor"
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}   {capacity}%",
        "format-charging": "п—§  {capacity}%",
        "format-plugged": "п‡¦  {capacity}%",
        "format-alt": "{icon}  {time}",
        "format-icons": ["п‰„ ", "п‰ѓ ", "п‰‚ ", "п‰Ѓ ", "п‰Ђ "]
    },

    "pulseaudio": {
        "format": "{icon}   {volume}%",
        "format-bluetooth": "{volume}%  {icon}пЉ” {format_source}",
        "format-bluetooth-muted": "пљ© {icon}пЉ” {format_source}",
        "format-muted": "пљ© {format_source}",
        "format-source": "{volume}% п„°",
        "format-source-muted": "п„±",
        "format-icons": {
            "headphone": "пЂҐ ",
            "hands-free": "п–ђ ",
            "headset": "п–ђ ",
            "phone": "п‚• ",
            "portable": "п‚• ",
            "car": "п†№ ",
            "default": ["пЂ¦ ", "пЂЁ ", "пЂЁ "]
        },
        "on-click": "pavucontrol"
    },

    "bluetooth": {
        "format": "пЉ“ {status}",
        "format-disabled": "",
        "format-off": "",
        "interval": 30,
        "on-click": "blueman-manager",
        "format-no-controller": ""
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "tooltip": true,
        "format-icons":{
            "activated": "пЏЃ",
            "deactivated": "пЂЈ"
        },
        "on-click-right": "hyprlock"        
    }
}
